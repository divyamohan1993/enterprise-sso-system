#
# MILNET SSO System — Hardened Linux Kernel Configuration
# =======================================================
#
# Target: Linux 6.12 LTS (x86_64)
# Purpose: Military-grade SSO appliance running 8 Rust services + PostgreSQL
# Hardware: Bare metal or cloud VM with TPM 2.0, no peripherals
#
# Design philosophy:
#   - Minimal attack surface: every disabled subsystem is one fewer exploit vector
#   - Fail-closed: if integrity checks fail, the kernel panics rather than degrading
#   - No modules: the entire kernel is monolithic — no loadable code post-boot
#   - No debug interfaces: no kprobes, ftrace, debugfs, BPF, or kallsyms
#   - No legacy: no 32-bit compat, no virtual terminals, no USB
#
# CLASSIFICATION: UNCLASSIFIED // FOUO
# Generated for MILNET SSO bare-metal deployment
#

# ===========================================================================
# ARCHITECTURE & CORE
# ===========================================================================
# 64-bit only. No 32-bit compatibility reduces syscall attack surface by ~50%.
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_X86=y
# SMP required for multi-core service parallelism
CONFIG_SMP=y
CONFIG_NR_CPUS=64
# Full preemption for bounded latency on crypto operations
CONFIG_PREEMPT=y
CONFIG_HZ_1000=y
# Tickless operation on non-boot CPUs — reduces interrupt attack surface
CONFIG_NO_HZ_FULL=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_POSIX_TIMERS=y

# ===========================================================================
# BOOT — EFI SECURE BOOT
# ===========================================================================
# EFI stub allows direct boot without a bootloader (reduces TOCTOU window)
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_ACPI=y
# Enforce Secure Boot signature chain from firmware through kernel
CONFIG_EFI_SECURE_BOOT_SIG_ENFORCE=y

# ===========================================================================
# NO LOADABLE MODULES
# ===========================================================================
# Rationale: Loadable modules are the #1 vector for kernel rootkits.
# A monolithic kernel with no module support means:
#   - No insmod/modprobe attack surface
#   - No /proc/modules, /sys/module to inspect
#   - All drivers compiled in — no TOCTOU between load and verify
#   - MODULE_SIG becomes moot (nothing to sign)
# This is the single most impactful hardening decision.
# CONFIG_MODULES is not set

# ===========================================================================
# MODULE SIGNING (compile-time only, modules are disabled)
# ===========================================================================
# These are set for completeness if modules are ever re-enabled during
# development. In production with MODULES=n, they have no effect.
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=y
CONFIG_MODULE_SIG_SHA512=y

# ===========================================================================
# FILESYSTEM — MINIMAL SET
# ===========================================================================
# Only ext4 for data partition. Root is dm-verity protected (read-only).
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
# tmpfs for /tmp, /run — never touches disk
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
# Pseudo-filesystems required by userspace
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
# Auto-mount /dev at boot — no need for udev in initramfs
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
# securityfs for LSM interaction
CONFIG_SECURITYFS=y

# No network filesystems — all data is local
# CONFIG_NFS_FS is not set
# CONFIG_CIFS is not set
# CONFIG_SMB_SERVER is not set
# CONFIG_9P_FS is not set

# No FUSE — eliminates userspace filesystem attack surface
# CONFIG_FUSE_FS is not set

# ===========================================================================
# NETWORKING — TCP/IP ONLY
# ===========================================================================
# The SSO system communicates exclusively over TCP (HTTPS/gRPC).
# No UDP services, no raw sockets for unprivileged users.
CONFIG_NET=y
CONFIG_INET=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_IPV6=y
# Unix domain sockets for PostgreSQL local connections
CONFIG_UNIX=y

# --- Netfilter (firewall) ---
# nftables for stateful packet filtering. All ports except 443 and 5432
# (localhost only) are DROP by default.
CONFIG_NETFILTER=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_CT=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_LOG=y
CONFIG_NFT_REJECT=y
CONFIG_NF_CONNTRACK=y

# No wireless/Bluetooth — zero RF attack surface
# CONFIG_WIRELESS is not set
# CONFIG_BT is not set
# CONFIG_CFG80211 is not set
# CONFIG_MAC80211 is not set

# ===========================================================================
# BLOCK DEVICES & STORAGE
# ===========================================================================
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_ATA=y
CONFIG_SATA_AHCI=y

# VirtIO for cloud/VM deployments (GCP, AWS)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=y

# Device-mapper for dm-verity and dm-crypt (LUKS)
CONFIG_BLK_DEV_DM=y
CONFIG_DM_CRYPT=y
# dm-verity: cryptographic verification of every block read from rootfs
CONFIG_DM_VERITY=y
# Require signed root hash — unsigned verity trees are rejected
CONFIG_DM_VERITY_VERIFY_ROOTHASH_SIG=y

# ===========================================================================
# TPM 2.0 — HARDWARE ROOT OF TRUST
# ===========================================================================
# TPM is used for:
#   - Sealing LUKS keys to PCR state (measured boot)
#   - Platform attestation (remote verification of boot chain)
#   - Entropy generation (TRNG)
# All TPM drivers are built-in (no modules).
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS=y
CONFIG_TCG_TIS_CORE=y
CONFIG_TCG_CRB=y
# vTPM proxy for cloud deployments (GCP Shielded VM, AWS Nitro)
CONFIG_TCG_VTPM_PROXY=y

# ===========================================================================
# CRYPTOGRAPHIC HARDWARE ACCELERATION
# ===========================================================================
# Intel AES-NI provides ~10x speedup for AES-256-GCM (TLS 1.3)
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES_NI_INTEL=y
# SHA-256/512 acceleration for certificate verification, HMAC, key derivation
CONFIG_CRYPTO_SHA256_SSSE3=y
CONFIG_CRYPTO_SHA512_SSSE3=y
# GHASH for AES-GCM mode (TLS 1.3 cipher suites)
CONFIG_CRYPTO_GHASH_CLMUL_NI_INTEL=y
# ChaCha20-Poly1305 for mobile clients (no AES-NI)
CONFIG_CRYPTO_CHACHA20_X86_64=y
CONFIG_CRYPTO_POLY1305_X86_64=y
# XTS for LUKS full-disk encryption
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_HMAC=y

# ===========================================================================
# ENTROPY SOURCES — CRITICAL FOR ALL CRYPTO
# ===========================================================================
# Multiple entropy sources ensure /dev/urandom never blocks or becomes
# predictable. Hardware RNG is mixed into the kernel entropy pool.
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_INTEL=y
CONFIG_HW_RANDOM_AMD=y
CONFIG_HW_RANDOM_VIRTIO=y
# Trust CPU RDRAND at boot — seeds pool before userspace starts
# This is acceptable when running on trusted hardware (our own metal)
CONFIG_RANDOM_TRUST_CPU=y

# ===========================================================================
# LINUX SECURITY MODULES (LSM)
# ===========================================================================
CONFIG_SECURITY=y
# Lockdown LSM: prevents userspace from modifying kernel at runtime
# CONFIDENTIALITY mode blocks: kexec, /dev/mem, ioport, hibernation,
# PCI BAR access, raw MSR access, and more
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y
# Yama LSM: restricts ptrace (prevents process memory dumping)
CONFIG_SECURITY_YAMA=y
# Landlock LSM: unprivileged sandboxing for MILNET Rust services
CONFIG_SECURITY_LANDLOCK=y

# --- Audit subsystem ---
# Required for security event logging (login attempts, key access, etc.)
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y

# ===========================================================================
# KERNEL HARDENING — MEMORY SAFETY
# ===========================================================================
# KASLR: randomize kernel base address at each boot
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
# Stack canaries: detect stack buffer overflows
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
# FORTIFY_SOURCE: compile-time and runtime buffer overflow detection
CONFIG_FORTIFY_SOURCE=y
# Hardened usercopy: bounds-check copy_to/from_user
CONFIG_HARDENED_USERCOPY=y
# Zero all heap allocations and freed memory — prevents info leaks
# and use-after-free exploitation
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
# KFENCE: lightweight memory safety error detector (low overhead)
CONFIG_KFENCE=y
# Page table isolation: Meltdown mitigation (separate kernel/user page tables)
CONFIG_PAGE_TABLE_ISOLATION=y
# Retpoline: Spectre v2 mitigation (indirect branch thunks)
CONFIG_RETPOLINE=y
# Control Flow Integrity: prevent ROP/JOP attacks (requires Clang)
CONFIG_CFI_CLANG=y
# Shadow call stack: protect return addresses on a separate stack
CONFIG_SHADOW_CALL_STACK=y
# Randomize kernel stack offset on syscall entry
CONFIG_RANDOMIZE_KSTACK_OFFSET=y
CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT=y

# ===========================================================================
# ATTACK SURFACE REDUCTION — DISABLED SUBSYSTEMS
# ===========================================================================

# --- No USB ---
# TPM 2.0 is on LPC/SPI bus. No USB devices are ever attached.
# Disabling USB eliminates BadUSB, USB HID injection, and USB driver bugs.
# CONFIG_USB is not set
# CONFIG_USB_SUPPORT is not set

# --- No display/audio/input ---
# Headless server. Management is via SSH over the network only.
# CONFIG_SOUND is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_VT is not set
# CONFIG_INPUT is not set

# --- No debugging interfaces ---
# These are information disclosure vectors in production.
# kprobes/ftrace allow arbitrary kernel function hooking.
# debugfs exposes internal kernel state.
# kallsyms maps addresses to symbols (aids exploit development).
# BPF syscall is used in multiple privilege escalation exploits.
# CONFIG_KPROBES is not set
# CONFIG_FTRACE is not set
# CONFIG_PROFILING is not set
# CONFIG_DEBUG_FS is not set
# CONFIG_KALLSYMS is not set
# CONFIG_BPF_SYSCALL is not set
# CONFIG_USERFAULTFD is not set

# --- No legacy/compat ---
# 32-bit syscall emulation doubles the attack surface for syscall exploits.
# CONFIG_COMPAT is not set
# CONFIG_IA32_EMULATION is not set

# --- No core dumps ---
# Core dumps can leak cryptographic keys, tokens, and PII from memory.
# CONFIG_COREDUMP is not set

# --- No swap ---
# Swap writes memory contents (potentially keys, tokens) to disk in plaintext.
# All MILNET services pin sensitive memory with mlock().
# CONFIG_SWAP is not set

# --- No container primitives ---
# This is bare metal. Namespaces and cgroups are not needed and are
# frequently used in container escape and privilege escalation exploits.
# CONFIG_NAMESPACES is not set
# CONFIG_USER_NS is not set
# CONFIG_CGROUPS is not set

# --- IPC ---
# SYSVIPC is REQUIRED by PostgreSQL for shared memory segments.
# POSIX message queues are not used by any MILNET component.
CONFIG_SYSVIPC=y
# CONFIG_POSIX_MQUEUE is not set

# ===========================================================================
# MISCELLANEOUS
# ===========================================================================
# Needed for systemd or service management
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_EPOLL=y
CONFIG_INOTIFY_USER=y
# Needed for LUKS/dm-crypt
CONFIG_KEYS=y
CONFIG_ENCRYPTED_KEYS=y
CONFIG_TRUSTED_KEYS=y

# End of MILNET kernel configuration
