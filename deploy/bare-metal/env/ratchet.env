# ==============================================================================
# MILNET SSO — Ratchet Environment Configuration
# ==============================================================================
# Install to: /etc/milnet/ratchet.env
# Owner: root:milnet-ratchet  Permissions: 0640
# ==============================================================================

# ── Service binding ──────────────────────────────────────────────────────────
RATCHET_ADDR=127.0.0.1:9105

# ── Backend service addresses ────────────────────────────────────────────────
ORCHESTRATOR_ADDR=127.0.0.1:9101
VERIFIER_ADDR=127.0.0.1:9104
AUDIT_ADDR=127.0.0.1:9108

# ── Session ratchet interval ────────────────────────────────────────────────
RATCHET_INTERVAL_SECS=300

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Data directory ───────────────────────────────────────────────────────────
MILNET_DATA_DIR=/var/lib/milnet/ratchet
