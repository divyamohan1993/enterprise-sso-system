# ==============================================================================
# MILNET SSO — Audit Environment Configuration
# ==============================================================================
# Install to: /etc/milnet/audit.env
# Owner: root:milnet-audit  Permissions: 0640
# ==============================================================================

# ── Service binding ──────────────────────────────────────────────────────────
AUDIT_ADDR=127.0.0.1:9108

# ── Database ─────────────────────────────────────────────────────────────────
# Audit uses a separate database user with INSERT-only privileges on
# audit tables. This prevents a compromised audit service from modifying
# or deleting existing audit records.
DATABASE_URL=postgresql://milnet_audit:CHANGEME@127.0.0.1:5432/milnet_sso

# ── Data directories ────────────────────────────────────────────────────────
AUDIT_DATA_DIR=/var/lib/milnet/audit
AUDIT_ALERTS_DIR=/var/lib/milnet/alerts

# ── Retention ────────────────────────────────────────────────────────────────
AUDIT_RETENTION_DAYS=365

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Data directory ───────────────────────────────────────────────────────────
MILNET_DATA_DIR=/var/lib/milnet/audit
