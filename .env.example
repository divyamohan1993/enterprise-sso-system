# =============================================================
# ENTERPRISE SSO SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================

# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
# API_PREFIX=api/v1

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=sso_admin
DB_PASS=<SECURE_DATABASE_PASSWORD>
DB_NAME=sso_db
DB_SSL=false

# JWT Configuration
# Generate with: openssl rand -base64 64
JWT_SECRET=<GENERATE_64_PLUS_CHARACTER_SECRET>
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Cookie Secret (for signed cookies)
# Generate with: openssl rand -base64 32
COOKIE_SECRET=<GENERATE_32_PLUS_CHARACTER_SECRET>

# OAuth / OIDC Configuration
OAUTH_ISSUER=https://your-domain.com
OAUTH_CLIENT_ID=sso_default_client
OAUTH_CLIENT_SECRET=<YOUR_CLIENT_SECRET>
OAUTH_REDIRECT_URI=https://your-domain.com/callback

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>

# CORS - Comma-separated list of allowed origins
CORS_ORIGIN=https://your-domain.com,https://app.your-domain.com

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Redis (Recommended for production session storage)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<REDIS_PASSWORD>

# Initial Admin Password (First-time setup only)
# CHANGE THIS IMMEDIATELY AFTER FIRST LOGIN
ADMIN_INITIAL_PASSWORD=<SECURE_INITIAL_PASSWORD>

# Feature Flags
MFA_REQUIRED=false
AUDIT_LOG_ENABLED=true
