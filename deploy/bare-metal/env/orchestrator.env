# ==============================================================================
# MILNET SSO — Orchestrator Environment Configuration
# ==============================================================================
# Install to: /etc/milnet/orchestrator.env
# Owner: root:milnet-orchestrator  Permissions: 0640
# ==============================================================================

# ── Service binding ──────────────────────────────────────────────────────────
ORCH_LISTEN_ADDR=127.0.0.1:9101

# ── Backend service addresses ────────────────────────────────────────────────
OPAQUE_ADDR=127.0.0.1:9102
TSS_ADDR=127.0.0.1:9103
RATCHET_ADDR=127.0.0.1:9105
AUDIT_ADDR=127.0.0.1:9108

# ── Database ─────────────────────────────────────────────────────────────────
# Use a dedicated milnet user with minimal privileges (SELECT, INSERT, UPDATE
# on auth tables only). Password loaded from a secrets file or vault.
DATABASE_URL=postgresql://milnet:CHANGEME@127.0.0.1:5432/milnet_sso

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Data directory ───────────────────────────────────────────────────────────
MILNET_DATA_DIR=/var/lib/milnet/orchestrator
