# ==============================================================================
# MILNET SSO — TSS (Threshold Signing) Base Environment Configuration
# ==============================================================================
# Install to: /etc/milnet/tss.env
# Owner: root:milnet-tss  Permissions: 0640
#
# This is the SHARED configuration for all TSS nodes. Per-node overrides
# (node ID, listen port, peer addresses) are in tss-node-{1..5}.env.
# ==============================================================================

# ── FROST configuration ─────────────────────────────────────────────────────
# 3-of-5 threshold scheme: any 3 of 5 nodes can produce a signature.
TSS_TOTAL_NODES=5
TSS_THRESHOLD=3

# ── Backend service addresses ────────────────────────────────────────────────
ORCHESTRATOR_ADDR=127.0.0.1:9101
VERIFIER_ADDR=127.0.0.1:9104
AUDIT_ADDR=127.0.0.1:9108

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info
