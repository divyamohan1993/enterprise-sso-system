# ==============================================================================
# MILNET SSO — Gateway Environment Configuration
# ==============================================================================
# Install to: /etc/milnet/gateway.env
# Owner: root:milnet-gateway  Permissions: 0640
# ==============================================================================

# ── Service binding ──────────────────────────────────────────────────────────
# Public-facing port for puzzle challenge + X-Wing KEM exchange.
GATEWAY_PORT=9100
GATEWAY_BIND_ADDR=0.0.0.0

# ── Backend service addresses ────────────────────────────────────────────────
# Orchestrator is the only backend gateway communicates with directly.
ORCHESTRATOR_ADDR=127.0.0.1:9101

# ── Audit logging ───────────────────────────────────────────────────────────
AUDIT_ADDR=127.0.0.1:9108

# ── Puzzle challenge configuration ──────────────────────────────────────────
# Difficulty level for client puzzle challenges (bits of leading zeros).
# Higher = harder = more DoS protection but slower legitimate clients.
GATEWAY_PUZZLE_DIFFICULTY=20

# ── Rate limiting ────────────────────────────────────────────────────────────
# Maximum new connections per source IP per window.
RATE_LIMIT_WINDOW_SECS=60
RATE_LIMIT_MAX_PER_IP=10
RATE_LIMIT_MAX_CONCURRENT=1000

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Data directory ───────────────────────────────────────────────────────────
MILNET_DATA_DIR=/var/lib/milnet/gateway
