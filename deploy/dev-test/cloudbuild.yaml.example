# ==============================================================================
# MILNET SSO — Cloud Build Configuration
# ==============================================================================
# Builds all 8 service Docker images and pushes to Artifact Registry.
#
# Usage:
#   gcloud builds submit . --config=deploy/dev-test/cloudbuild.yaml \
#     --project=YOUR_PROJECT --region=asia-south1
# ==============================================================================

substitutions:
  _REPO: asia-south1-docker.pkg.dev/YOUR_PROJECT_ID/milnet-sso-dev

options:
  machineType: E2_HIGHCPU_8
  logging: CLOUD_LOGGING_ONLY
  substitution_option: ALLOW_LOOSE

timeout: 3600s

steps:
  # Step 1: Build all binaries in a single builder stage (maximizes cache reuse)
  - name: gcr.io/cloud-builders/docker
    id: build-all
    args:
      - build
      - --target=builder
      - --tag=builder:latest
      - -f=Dockerfile
      - .
    waitFor: ['-']

  # Step 2: Build each service image (reuses builder cache)
  - name: gcr.io/cloud-builders/docker
    id: img-gateway
    args: ['build', '--build-arg=SERVICE_NAME=gateway', '-t', '${_REPO}/gateway:latest', '.']
    waitFor: ['build-all']

  - name: gcr.io/cloud-builders/docker
    id: img-orchestrator
    args: ['build', '--build-arg=SERVICE_NAME=orchestrator', '-t', '${_REPO}/orchestrator:latest', '.']
    waitFor: ['build-all']

  - name: gcr.io/cloud-builders/docker
    id: img-opaque
    args: ['build', '--build-arg=SERVICE_NAME=opaque', '-t', '${_REPO}/opaque:latest', '.']
    waitFor: ['build-all']

  - name: gcr.io/cloud-builders/docker
    id: img-tss
    args: ['build', '--build-arg=SERVICE_NAME=tss', '-t', '${_REPO}/tss:latest', '.']
    waitFor: ['build-all']

  - name: gcr.io/cloud-builders/docker
    id: img-verifier
    args: ['build', '--build-arg=SERVICE_NAME=verifier', '-t', '${_REPO}/verifier:latest', '.']
    waitFor: ['build-all']

  - name: gcr.io/cloud-builders/docker
    id: img-admin
    args: ['build', '--build-arg=SERVICE_NAME=admin', '-t', '${_REPO}/admin:latest', '.']
    waitFor: ['build-all']

  - name: gcr.io/cloud-builders/docker
    id: img-ratchet
    args: ['build', '--build-arg=SERVICE_NAME=ratchet', '-t', '${_REPO}/ratchet:latest', '.']
    waitFor: ['build-all']

  - name: gcr.io/cloud-builders/docker
    id: img-audit
    args: ['build', '--build-arg=SERVICE_NAME=audit', '-t', '${_REPO}/audit:latest', '.']
    waitFor: ['build-all']

images:
  - '${_REPO}/gateway:latest'
  - '${_REPO}/orchestrator:latest'
  - '${_REPO}/opaque:latest'
  - '${_REPO}/tss:latest'
  - '${_REPO}/verifier:latest'
  - '${_REPO}/admin:latest'
  - '${_REPO}/ratchet:latest'
  - '${_REPO}/audit:latest'
