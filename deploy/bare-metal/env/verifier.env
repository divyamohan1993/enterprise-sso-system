# ==============================================================================
# MILNET SSO — Verifier Environment Configuration
# ==============================================================================
# Install to: /etc/milnet/verifier.env
# Owner: root:milnet-verifier  Permissions: 0640
# ==============================================================================

# ── Service binding ──────────────────────────────────────────────────────────
VERIFIER_ADDR=127.0.0.1:9104

# ── Backend service addresses ────────────────────────────────────────────────
TSS_ADDR=127.0.0.1:9103
RATCHET_ADDR=127.0.0.1:9105
AUDIT_ADDR=127.0.0.1:9108

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Data directory ───────────────────────────────────────────────────────────
MILNET_DATA_DIR=/var/lib/milnet/verifier
