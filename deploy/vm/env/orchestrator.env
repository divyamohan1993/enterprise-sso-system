# MILNET Orchestrator — Environment Configuration Template
#
# Copy this file and replace all REPLACE_WITH_* placeholders with actual values.
# This file contains secrets — protect with chmod 640 and chown root:milnet.

# ── Production Mode ────────────────────────────────────────────────────────────
# Enforces hardware HSM, blocks dev mode, requires TLS everywhere.
MILNET_PRODUCTION=1
MILNET_MILITARY_DEPLOYMENT=1
MILNET_PQ_TLS_ONLY=1
MILNET_FIPS_MODE=1

# ── Service Identity ──────────────────────────────────────────────────────────
# Unique node ID for this orchestrator instance (e.g., orchestrator-0)
MILNET_NODE_ID=REPLACE_WITH_NODE_ID
MILNET_SERVICE_TYPE=orchestrator
# This node's service address (visible to other cluster members)
MILNET_SERVICE_ADDR=REPLACE_WITH_THIS_VM_IP:9101
# Listen address (0.0.0.0 to accept from all interfaces)
ORCH_LISTEN_ADDR=0.0.0.0:9101

# ── Raft Cluster ──────────────────────────────────────────────────────────────
# Raft transport address for leader election
MILNET_RAFT_ADDR=REPLACE_WITH_THIS_VM_IP:9090
# Comma-separated list of all Raft peers (including this node)
# Format: host1:raft_port,host2:raft_port,host3:raft_port
MILNET_CLUSTER_PEERS=REPLACE_WITH_VM2_IP:9090,REPLACE_WITH_VM3_IP:9090,REPLACE_WITH_VM4_IP:9090

# ── Downstream Service Addresses ──────────────────────────────────────────────
OPAQUE_ADDR=REPLACE_WITH_OPAQUE_HOST:9102
TSS_ADDR=REPLACE_WITH_TSS_COORDINATOR_HOST:9103
VERIFIER_ADDR=REPLACE_WITH_VERIFIER_HOST:9104
RATCHET_ADDR=REPLACE_WITH_RATCHET_HOST:9105
RISK_ADDR=REPLACE_WITH_RISK_HOST:9106
AUDIT_ADDR=REPLACE_WITH_AUDIT_HOST:9108
KT_ADDR=REPLACE_WITH_KT_HOST:9109

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string for session state persistence
DATABASE_URL=postgres://milnet:REPLACE_WITH_DB_PASSWORD@REPLACE_WITH_DB_HOST:5432/milnet_sso?sslmode=require

# ── Cryptographic Key Material ────────────────────────────────────────────────
# 32-byte hex-encoded master Key Encryption Key (64 hex chars)
MILNET_MASTER_KEK=REPLACE_WITH_64_HEX_CHAR_MASTER_KEK

# ── HSM Configuration ────────────────────────────────────────────────────────
# Backend: pkcs11, aws-kms, or tpm2 (required when MILNET_PRODUCTION=1)
MILNET_HSM_BACKEND=REPLACE_WITH_HSM_BACKEND
# PKCS#11 settings (if HSM_BACKEND=pkcs11)
MILNET_PKCS11_LIB=REPLACE_WITH_PKCS11_SO_PATH
MILNET_PKCS11_SLOT=REPLACE_WITH_SLOT_NUMBER
MILNET_PKCS11_PIN=REPLACE_WITH_HSM_PIN
MILNET_HSM_KEY_LABEL=milnet-orchestrator-kek
# AWS KMS settings (if HSM_BACKEND=aws-kms)
# MILNET_AWS_KMS_KEY_ID=REPLACE_WITH_KMS_KEY_ARN
# MILNET_AWS_KMS_REGION=REPLACE_WITH_AWS_REGION
# TPM2 settings (if HSM_BACKEND=tpm2)
# MILNET_TPM2_DEVICE=/dev/tpm0
# MILNET_TPM2_PCRS=0,1,2,3,7

# ── TLS Certificate Rotation ─────────────────────────────────────────────────
MILNET_CERT_LIFETIME_HOURS=720
MILNET_CERT_ROTATION_THRESHOLD=0.8

# ── Adaptive Crypto ──────────────────────────────────────────────────────────
MILNET_ADAPTIVE_DEBOUNCE_SECS=10

# ── SIEM Integration ─────────────────────────────────────────────────────────
MILNET_SIEM_WEBHOOK_URL=REPLACE_WITH_SIEM_URL
MILNET_SIEM_AUTH_TOKEN=REPLACE_WITH_SIEM_TOKEN
MILNET_SIEM_BATCH_SIZE=25
MILNET_SIEM_FLUSH_INTERVAL_SECS=60
MILNET_SIEM_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info,milnet=debug
