# ==============================================================================
# MILNET SSO — Docker Build Context Exclusions
# ==============================================================================
# Prevents secrets, credentials, build artifacts, and unnecessary files from
# leaking into container images.

# ── Build artifacts ───────────────────────────────────────────────────────────
target/

# ── Git ───────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitmodules

# ── Documentation ─────────────────────────────────────────────────────────────
*.md
screenshots/
docs/
formal-model/

# ── Fuzz targets (not needed in production) ───────────────────────────────────
fuzz/

# ── Secrets and credentials ───────────────────────────────────────────────────
.env
.env.*
.env.local
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
credentials.json
service-account*.json
**/secrets/
**/secret/

# ── Cloud provider credentials ────────────────────────────────────────────────
**/.aws/
**/.gcp/
**/.azure/
**/gcloud/
**/.config/gcloud/

# ── Kubernetes configs ────────────────────────────────────────────────────────
.kube/
**/.kube/
kubeconfig*

# ── CI/CD ─────────────────────────────────────────────────────────────────────
.github/

# ── IDE and editor files ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ── Terraform state (contains secrets) ────────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
**/.terraform/
*.tfvars
terraform.tfvars

# ── SBOM and security scan outputs ────────────────────────────────────────────
sbom*.json
sbom*.json.bundle
trivy-results-*.sarif
*.sarif

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.bak
*.tmp
*.orig
