{
  "dashboard": {
    "id": null,
    "uid": "milnet-sso-overview",
    "title": "MILNET SSO Security Overview",
    "tags": ["milnet", "sso", "security", "military-grade"],
    "timezone": "utc",
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Authentication Latency (p50/p95/p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(milnet_auth_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(milnet_auth_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(milnet_auth_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1, "color": "yellow" },
                { "value": 3, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Auth Success / Failure Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(milnet_auth_total{result=\"success\"}[5m]))",
            "legendFormat": "Success/sec"
          },
          {
            "expr": "sum(rate(milnet_auth_total{result=\"failure\"}[5m]))",
            "legendFormat": "Failure/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "bars",
              "stacking": { "mode": "normal" }
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Error Rate by Service",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(milnet_request_errors_total[5m])) by (service)",
            "legendFormat": "{{ service }}"
          }
        ]
      },
      {
        "id": 4,
        "title": "Puzzle Difficulty Distribution",
        "type": "heatmap",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(milnet_puzzle_difficulty_bucket[5m])) by (le)",
            "legendFormat": "{{ le }}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Active Sessions",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "milnet_active_sessions",
            "legendFormat": "Active Sessions"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 100, "color": "yellow" },
                { "value": 500, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Revocation List Size",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
        "targets": [
          {
            "expr": "milnet_revocation_list_size",
            "legendFormat": "Revoked Tokens"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1000, "color": "yellow" },
                { "value": 5000, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Risk Score Distribution",
        "type": "histogram",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "targets": [
          {
            "expr": "sum(rate(milnet_risk_score_bucket[5m])) by (le)",
            "legendFormat": "{{ le }}"
          }
        ]
      },
      {
        "id": 8,
        "title": "Ratchet Epoch Distribution",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "targets": [
          {
            "expr": "milnet_ratchet_current_epoch",
            "legendFormat": "Current Epoch"
          },
          {
            "expr": "sum(rate(milnet_ratchet_advances_total[5m]))",
            "legendFormat": "Advances/sec"
          }
        ]
      },
      {
        "id": 9,
        "title": "Connection Counts by Service",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
        "targets": [
          {
            "expr": "milnet_active_connections",
            "legendFormat": "{{ service }}"
          }
        ]
      },
      {
        "id": 10,
        "title": "Circuit Breaker State",
        "type": "state-timeline",
        "gridPos": { "h": 4, "w": 12, "x": 12, "y": 28 },
        "targets": [
          {
            "expr": "milnet_circuit_breaker_state",
            "legendFormat": "{{ service }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "0": { "text": "Closed", "color": "green" } } },
              { "type": "value", "options": { "1": { "text": "HalfOpen", "color": "yellow" } } },
              { "type": "value", "options": { "2": { "text": "Open", "color": "red" } } }
            ]
          }
        }
      },
      {
        "id": 11,
        "title": "SIEM Events by Severity",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
        "targets": [
          {
            "expr": "sum(rate(milnet_siem_events_total[5m])) by (severity)",
            "legendFormat": "{{ severity }}"
          }
        ],
        "fieldConfig": {
          "overrides": [
            { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] },
            { "matcher": { "id": "byName", "options": "HIGH" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange" } }] },
            { "matcher": { "id": "byName", "options": "MEDIUM" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow" } }] },
            { "matcher": { "id": "byName", "options": "LOW" }, "properties": [{ "id": "color", "value": { "fixedColor": "green" } }] }
          ]
        }
      },
      {
        "id": 12,
        "title": "Incident Response: Open Incidents",
        "type": "table",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
        "targets": [
          {
            "expr": "milnet_incidents_active",
            "legendFormat": "{{ severity }} - {{ incident_type }}"
          }
        ]
      },
      {
        "id": 13,
        "title": "KMS Operations Latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(milnet_kms_operation_seconds_bucket[5m])) by (le, operation))",
            "legendFormat": "{{ operation }} p95"
          }
        ]
      },
      {
        "id": 14,
        "title": "Database Connection Pool",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
        "targets": [
          {
            "expr": "milnet_db_pool_active",
            "legendFormat": "Active"
          },
          {
            "expr": "milnet_db_pool_idle",
            "legendFormat": "Idle"
          },
          {
            "expr": "milnet_db_pool_max",
            "legendFormat": "Max"
          }
        ]
      }
    ]
  }
}
