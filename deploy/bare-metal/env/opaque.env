# ==============================================================================
# MILNET SSO — OPAQUE Environment Configuration
# ==============================================================================
# Install to: /etc/milnet/opaque.env
# Owner: root:milnet-opaque  Permissions: 0640
# ==============================================================================

# ── Service binding ──────────────────────────────────────────────────────────
# Binds to localhost only — unreachable from external networks.
OPAQUE_ADDR=127.0.0.1:9102

# ── Backend service addresses ────────────────────────────────────────────────
ORCHESTRATOR_ADDR=127.0.0.1:9101
AUDIT_ADDR=127.0.0.1:9108

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Data directory ───────────────────────────────────────────────────────────
MILNET_DATA_DIR=/var/lib/milnet/opaque
