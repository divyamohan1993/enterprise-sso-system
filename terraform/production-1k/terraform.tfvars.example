# Copy to terraform.tfvars and customize
project_id  = "your-gcp-project-id"
region      = "us-central1"
environment = "production"
domain      = "sso.yourdomain.com"

# Database
db_tier = "db-custom-8-32768" # 8 vCPU, 32 GB RAM
db_ha   = true                # REGIONAL HA — doubles DB cost but zero-downtime failover

# Redis
redis_memory_gb = 4 # 4 GB for sessions + revocation list

# GKE scaling
gke_general_min_nodes = 3
gke_general_max_nodes = 8
gke_compute_min_nodes = 2
gke_compute_max_nodes = 5
tss_signer_count      = 5 # Must be >= 5 for 3-of-5 FROST
audit_bft_count       = 7 # Must be >= 7 for 2-Byzantine tolerance

# Cloud Armor
enable_cloud_armor_enterprise = false # Set true if >4B requests/month
