# ============================================================================
# MILNET SSO — Dev/Test Configuration (Prod-Identical, Sandbox Cost)
# ============================================================================
# Every resource is the SAME TYPE as production — just lowest-cost SKU/tier.
# No mocks, no stubs, no dev shortcuts. Real Cloud KMS HSM, real Cloud SQL,
# real Cloud Run with mTLS. Identical architecture to prod deployment.
#
#   cp terraform.tfvars.example terraform.tfvars
#   ./deploy.sh
# ============================================================================

# GCP project
project_id = "lmsforshantithakur"

# Delhi region (asia-south1)
region = "asia-south1"
zone   = "asia-south1-a"

# Repository to clone and test
github_repo   = "https://github.com/divyamohan1993/enterprise-sso-system.git"
github_branch = "master"

# Developer mode: allows SSH from anywhere, enables verbose logging
developer_mode = true

# C2 Spot VM for fast Rust compilation and test runs
# c2-standard-4 = 4 vCPU, 16 GB RAM (Intel Cascade Lake, fast single-thread)
machine_type = "c2-standard-4"

# Log verbosity: "verbose" shows all test output, "error" shows only failures
log_level = "verbose"

# Auto-delete VM if tests fail (set false to keep VM for debugging)
auto_destroy_on_failure = true

# Cloud Run settings — real prod services at sandbox scale
cloud_run_min_instances = 0   # Scale to zero when idle (cheapest)
cloud_run_max_instances = 2   # Max instances per service
tss_replica_count       = 3   # TSS threshold nodes (3 = 2-of-3 threshold)
container_image_tag     = "latest"

# Database password (leave empty to auto-generate)
# db_password = "your-secure-password-here"
