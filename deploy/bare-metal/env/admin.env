# ==============================================================================
# MILNET SSO — Admin API Environment Configuration
# ==============================================================================
# Install to: /etc/milnet/admin.env
# Owner: root:milnet-admin  Permissions: 0640
# ==============================================================================

# ── Service binding ──────────────────────────────────────────────────────────
ADMIN_PORT=8080
ADMIN_BIND_ADDR=0.0.0.0

# ── Backend service addresses ────────────────────────────────────────────────
GATEWAY_ADDR=127.0.0.1:9100
ORCHESTRATOR_ADDR=127.0.0.1:9101
VERIFIER_ADDR=127.0.0.1:9104
RATCHET_ADDR=127.0.0.1:9105
AUDIT_ADDR=127.0.0.1:9108

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://milnet:CHANGEME@127.0.0.1:5432/milnet_sso

# ── Public URL ───────────────────────────────────────────────────────────────
SSO_BASE_URL=https://sso.milnet.example.com

# ── Google OAuth (optional) ─────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Developer mode ───────────────────────────────────────────────────────────
# WARNING: NEVER enable in production. Disables puzzle challenges and
# reduces cryptographic strength for faster development iteration.
DEVELOPER_MODE=false

# ── Data directory ───────────────────────────────────────────────────────────
MILNET_DATA_DIR=/var/lib/milnet/admin
